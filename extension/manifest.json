{
  "manifest_version": 3,
  "name": "ClearChain — Crypto Wallet Risk Scanner",
  "short_name": "ClearChain",
  "version": "0.2.0",
  "description": "Instantly scan any crypto wallet for OFAC sanctions, mixer interactions, and AML risk. Supports ETH, BTC, TRX, and SOL.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ClearChain — Scan a wallet"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      },
      "description": "Open ClearChain scanner"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "clipboardRead",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://clearchain.vercel.app/*",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon16.png", "icons/icon32.png", "icons/icon48.png", "icons/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
